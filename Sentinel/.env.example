GEMINI_API_KEY=your_actual_key_here
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=NOT_SET
NEXT_PUBLIC_MAPPLS_ACCESS_TOKEN=NOT_SET

# --- DOCKER DATABASE INITIALIZATION ---
# Docker uses these 3 lines to build the database the very first time
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=gigshield

# --- BACKEND CONNECTION STRINGS ---
# Notice we use 'db' and 'redis' instead of 'localhost', and added asyncpg
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/gigshield
REDIS_URL=redis://redis:6379/0